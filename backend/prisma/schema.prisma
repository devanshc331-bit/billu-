datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  oauthTokens   OAuthToken[]
  settings      Settings?
}

model OAuthToken {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String   @default("google")
  accessToken    String
  refreshToken   String
  tokenType      String   @default("Bearer")
  scope          String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Email {
  id              String           @id @default(cuid())
  messageId       String           @unique
  threadId        String?
  senderName      String?
  senderEmail     String
  recipients      String?
  subject         String?
  snippet         String?
  body            String?          // SQLite does not support @db.Text, maps to standard text field
  receivedAt      DateTime
  labels          String?          // JSON array stored as string
  attachments     String?          // JSON array stored as string
  importance      String?          // low, normal, high
  isRead          Boolean          @default(false)
  isStarred       Boolean          @default(false)
  headers         String?          // JSON stored as string
  // Derived fields
  containsDeadline    Boolean      @default(false)
  containsInvoice     Boolean      @default(false)
  containsMeeting     Boolean      @default(false)
  containsAttachment  Boolean      @default(false)
  containsActionItem  Boolean      @default(false)
  urgencyScore        Float        @default(0)
  priorityScore       Float        @default(0)
  senderReputation    String?      // known, unknown, important
  threadLength        Int          @default(1)
  // Status tracking
  status              String       @default("fetched")
  // fetched, normalized, classified, queued, approved, executed, completed
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  classifications     Classification[]
  jobs                Job[]
  auditLogs           AuditLog[]
}

model Rule {
  id            String   @id @default(cuid())
  name          String
  description   String?
  isActive      Boolean  @default(true)
  priority      Int      @default(0)
  // Conditions (stored as JSON)
  conditions    String   // JSON: [{ field, operator, value }]
  // Actions (stored as JSON)
  actions       String   // JSON: [{ type, config }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  classifications Classification[]
}

model Classification {
  id              String   @id @default(cuid())
  emailId         String
  email           Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  category        String
  confidenceScore Float
  features        String?  // JSON: extracted features
  ruleId          String?
  rule            Rule?    @relation(fields: [ruleId], references: [id])
  isApproved      Boolean  @default(false)
  approvedBy      String?  // user or "auto"
  approvedAt      DateTime?
  recommendedAction String?
  createdAt       DateTime @default(now())
}

model Job {
  id              String      @id @default(cuid())
  type            String      // sync, classify, create_task, create_reminder, apply_label, etc.
  status          String      @default("pending")
  // pending, running, completed, failed, retrying, dead
  emailId         String?
  email           Email?      @relation(fields: [emailId], references: [id])
  payload         String?     // JSON: job-specific data
  result          String?     // JSON: job result
  error           String?
  retryCount      Int         @default(0)
  maxRetries      Int         @default(5)
  nextRetryAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  jobLogs         JobLog[]
  retryQueue      RetryQueue?
  auditLogs       AuditLog[]
}

model JobLog {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  level       String   // info, warn, error
  message     String
  data        String?  // JSON
  duration    Int?     // milliseconds
  createdAt   DateTime @default(now())
}

model RetryQueue {
  id              String   @id @default(cuid())
  jobId           String   @unique
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  failureReason   String
  failureCategory String   // network, timeout, rate_limit, server_error, api_error, auth
  attemptNumber   Int      @default(1)
  nextRetryAt     DateTime
  backoffMs       Int
  isDead          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id            String   @id @default(cuid())
  emailId       String?
  email         Email?   @relation(fields: [emailId], references: [id])
  jobId         String?
  job           Job?     @relation(fields: [jobId], references: [id])
  action        String
  fromState     String?
  toState       String?
  actor         String   // system, user, auto
  details       String?  // JSON
  confidence    Float?
  userDecision  String?  // approved, rejected, edited, ignored
  createdAt     DateTime @default(now())
}

model NotionTask {
  id              String   @id @default(cuid())
  emailId         String   @unique
  notionPageId    String?
  title           String
  description     String?  // SQLite maps to text
  emailUrl        String?
  dueDate         DateTime?
  priority        String?  // low, medium, high, urgent
  status          String   @default("todo") // todo, in_progress, done
  labels          String?  // JSON array
  sender          String?
  notes           String?  // SQLite maps to text
  databaseId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarEvent {
  id              String   @id @default(cuid())
  emailId         String   @unique
  googleEventId   String?
  type            String   // reminder, meeting, follow_up, deadline
  title           String
  description     String?  // SQLite maps to text
  reminderTime    DateTime?
  location        String?
  attendees       String?  // JSON array
  duration        Int?     // minutes
  sourceEmail     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncInterval        Int      @default(15)  // minutes
  retryInterval       Int      @default(5)   // minutes
  cleanupInterval     Int      @default(1440) // minutes (24h)
  digestTime          String   @default("20:00")
  defaultCategory     String   @default("read_later")
  retryLimit          Int      @default(5)
  confidenceThresholdAuto Int @default(90)
  confidenceThresholdReview Int @default(70)
  notificationsEnabled Boolean @default(true)
  theme               String   @default("dark")
  fontSize            Int      @default(16)
  notionApiKey        String?
  notionDatabaseId    String?
  calendarEnabled     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RunHistory {
  id              String   @id @default(cuid())
  runType         String   // sync, classify, retry, cleanup, digest
  status          String   // running, completed, failed
  startedAt       DateTime
  completedAt     DateTime?
  emailsProcessed Int      @default(0)
  tasksCreated    Int      @default(0)
  eventsCreated   Int      @default(0)
  errors          Int      @default(0)
  duration        Int?     // milliseconds
  details         String?  // JSON
}
