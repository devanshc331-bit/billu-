# Server Configs
PORT=3001
NODE_ENV=development

# Database Configuration (SQLite)
DATABASE_URL="file:../storage/dev.db"

# Local AES-256 Token Encryption Key (32-byte hexadecimal string)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Mock/Sandbox Mode
# Set to false when connecting actual external APIs
MOCK_MODE=true

# Google OAuth API Settings (Optional if MOCK_MODE=true)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Notion Integration Settings (Optional if MOCK_MODE=true)
NOTION_API_KEY=secret_yournotionapikey
NOTION_DATABASE_ID=your_notion_database_id
